---
import { getCollection } from "astro:content";

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from "../layouts/BaseLayout.astro";

// Component Imports
import CallToAction from "../components/CallToAction.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import Pill from "../components/Pill.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";

// Page section components
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/Skills.astro";
import StatCard from "../components/StatCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";

// Content Fetching: List four most recent work projects
const projects = (await getCollection("work"))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

import { products } from "../data/products";
const featuredProducts = products.filter((p) =>
	[2, 40, 201].includes(Number(p.id)),
);

const liveWebsites = [
	{ name: "Coffee Lemon", url: "https://coffee-lemon-seven.vercel.app/", image: "/assets/live/coffee-lemon.jpg" },
	{ name: "Esmeralds", url: "https://esmeralds.vercel.app/", image: "/assets/live/esmeralds.jpg" },
	{ name: "Impcel", url: "https://impcel.vercel.app/", image: "/assets/live/impcel.jpg" },
	{ name: "Juice Khaki", url: "https://juice-khaki.vercel.app/", image: "/assets/live/juice-khaki.jpg" },
	{ name: "PC Master", url: "https://pc-master-chi.vercel.app/", image: "/assets/live/pc-master.jpg" },
	{ name: "Radical Customs", url: "https://radical-customs.vercel.app/", image: "/assets/live/radical-customs.jpg" },
	{ name: "Restaurants Coral", url: "https://restaurants-coral-two.vercel.app/", image: "/assets/live/restaurants-coral.jpg" },
	{ name: "Shoes Ten", url: "https://shoes-ten-orcin.vercel.app/", image: "/assets/live/shoes-ten.jpg" },
	{ name: "Catalogo Web", url: "https://catalogo-web-two.vercel.app/", image: "/assets/live/catalogo-web.jpg" },
	{ name: "MG Sports", url: "https://mg-sports.vercel.app/", image: "/assets/live/mg-sports.jpg" }
];



// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
	<script type="application/ld+json" slot="head">
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Mateo Ferrer - Desarrollador Web",
			"url": "https://portafolio-profesional.pages.dev/",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://portafolio-profesional.pages.dev/shop/?search={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		}
	</script>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20 reveal">
			<header class="hero">
				<Hero
					title="Hello, My name is Mateo Ferrer!"
					tagline="Master Software Engineer | Full Stack Developer | Dev Ops and IA Specialist | Software Enginner | +220 certified courses"
					align="center"
				>
					<div class="roles">
						<Pill
							><Icon icon="code" size="1.33em" /> Software Engineer</Pill
						>
						<Pill
							><Icon icon="rocket-launch" size="1.33em" /> E-Commerce</Pill
						>
						<Pill
							><Icon icon="pencil-line" size="1.33em" /> Marketing</Pill
						>
					</div>
					<div class="cta-buttons">
						<a href="/about/" class="cta-button primary">
							<Icon icon="arrow-right" size="1.2em" /> View My Work
						</a>
						<a
							href="https://wa.me/573005059987"
							target="_blank"
							rel="noopener noreferrer"
							class="cta-button secondary"
						>
							<Icon icon="paper-plane-tilt" size="1.2em" /> Let's Talk
						</a>
						<a
							href="/assets/HV_MATEOFERRER_2026-01.pdf"
							download
							class="cta-button secondary"
						>
							<Icon icon="paper-plane-tilt" size="1.2em" /> Download
							CV
						</a>
					</div>
				</Hero>



				<img
					alt="Portada Mateo Ferrer"
					width="480"
					height="620"
					src="/assets/portrait-new.jpg"
					id="hero-portrait"
					fetchpriority="high"
					loading="eager"
				/>
			</header>

			<script src="../scripts/homeUtils.ts"></script>

			<Skills />
		</div>

		<!-- Statistics Section -->
		<section class="stats-section wrapper reveal">
			<header class="section-header stack gap-2 lg:gap-4">
				<h2>By The Numbers</h2>
				<p>A snapshot of my professional journey and impact.</p>
			</header>
			<div class="stats-grid">
				<StatCard
					number="5+"
					label="Years of Experience"
					description="In Software Development & Design"
				/>
				<StatCard
					number="50+"
					label="Projects Completed"
					description="From startups to enterprises"
				/>
				<StatCard
					number="200+"
					label="Certifications"
					description="From Platzi, Google, Udemy & more"
				/>
				<StatCard
					number="100%"
					label="Client Satisfaction"
					description="Dedicated to excellence"
				/>
			</div>
		</section>

		<script>
			// ── Animated Number Counter ────────────────────────────────────────
			function animateCounter(el: HTMLElement, target: number, suffix: string, duration = 1600) {
				let start: number | null = null;
				const step = (timestamp: number) => {
					if (!start) start = timestamp;
					const progress = Math.min((timestamp - start) / duration, 1);
					// Ease out cubic
					const eased = 1 - Math.pow(1 - progress, 3);
					el.textContent = Math.floor(eased * target) + suffix;
					if (progress < 1) requestAnimationFrame(step);
				};
				requestAnimationFrame(step);
			}

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (!entry.isIntersecting) return;
					const numEl = entry.target.querySelector('.stat-number') as HTMLElement;
					if (!numEl || numEl.dataset.animated) return;
					numEl.dataset.animated = 'true';

					const raw = (numEl.dataset.value || numEl.textContent || '').trim();
					const suffix = raw.replace(/[\d,]+/, '');
					const target = parseInt(raw.replace(/\D/g, ''), 10);
					if (!isNaN(target)) animateCounter(numEl, target, suffix);
					observer.unobserve(entry.target);
				});
			}, { threshold: 0.4 });

			document.querySelectorAll('.stat').forEach(el => observer.observe(el));
		</script>

		<!-- Services Section -->
		<section class="services-section wrapper reveal">
			<header class="section-header stack gap-2 lg:gap-4">
				<h2>Services I Offer</h2>
				<p>Comprehensive solutions tailored to your needs.</p>
			</header>
			<div class="services-grid">
				<ServiceCard
					title="Full Stack Development"
					icon="code"
					description="Build scalable web applications with React, Angular, Astro, Node.js, and more."
				/>
				<ServiceCard
					title="UI/UX Design"
					icon="pencil-line"
					description="Create beautiful, user-centric interfaces that engage and convert."
				/>
				<ServiceCard
					title="DevOps & Cloud"
					icon="rocket-launch"
					description="Deploy and manage applications with confidence using modern DevOps practices."
				/>
				<ServiceCard
					title="AI Integration"
					icon="trophy"
					description="Leverage artificial intelligence to enhance your business processes."
				/>
				<ServiceCard
					title="Digital Marketing"
					icon="strategy"
					description="Drive growth through strategic digital marketing and social media management."
				/>
				<ServiceCard
					title="E-Commerce Solutions"
					icon="rocket-launch"
					description="Build robust, scalable e-commerce platforms that drive sales."
				/>
			</div>
		</section>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta reveal">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Featured Projects</h2>
					<p>
						Take a look below at some of my featured work for
						clients from the past few years.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All Projects
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<!-- Live Web Projects Section -->
			<section class="section with-background bg-variant reveal">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Live Web Experiences</h2>
					<p>
						Una colección de aplicaciones web y plataformas e-commerce diseñadas y desarrolladas para impacto en el mundo real.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							liveWebsites.map((site) => (
								<li class="web-card tilt-card">
									<a
										href={site.url}
										target="_blank"
										rel="noopener noreferrer"
										class="web-link"
									>
										<div class="web-image">
											<div class="browser-header">
												<span class="dot red"></span>
												<span class="dot yellow"></span>
												<span class="dot green"></span>
											</div>
											<img
												src={site.image}
												alt={`Screenshot of ${site.name}`}
												loading="lazy"
											/>
										</div>
										<div class="web-info">
											<h3>{site.name}</h3>
											<p class="web-url">{site.url.replace('https://', '').replace(/\/$/, '')}</p>
											<span class="visit-btn">Visitar Sitio <Icon icon="arrow-right" size="1.2em" /></span>
										</div>
									</a>
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<!-- Featured Products Section (NEW) -->
			<section class="section with-background reveal">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Destacados de la Tienda</h2>
					<p>
						Herramientas y recursos premium para llevar tu
						productividad al siguiente nivel.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							featuredProducts.map((product) => (
								<li class="product-card-home tilt-card">
									<a
										href={`/shop/#product-${product.id}`}
										class="product-link"
									>
										<div class="product-image">
											<img
												src={product.image}
												alt={product.name}
												loading="lazy"
											/>
											<span class="price-badge">
												{product.price}
											</span>
										</div>
										<div class="product-info">
											<h3>{product.name}</h3>
											<p>
												{product.category.toUpperCase()}
											</p>
										</div>
									</a>
								</li>
							))
						}
					</Grid>
				</div>
				<script src="../scripts/tilt.ts"></script>

				<div class="cta">
					<CallToAction href="/shop/">
						Ver Tienda Completa
						<Icon icon="shopping-cart" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<!-- Testimonials Section -->
			<section class="testimonials-section reveal">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>What Clients Say</h2>
					<p>
						Don't just take my word for it. Here's what my clients
						have to say about working with me.
					</p>
				</header>

				<div class="testimonials-grid">
					<TestimonialCard
						name="Sarah Johnson"
						role="CEO"
						company="TechStart Inc"
						comment="Mateo delivered an exceptional e-commerce platform that increased our sales by 150%. His professionalism and attention to detail is unmatched."
					/>
					<TestimonialCard
						name="Carlos Rodriguez"
						role="Project Manager"
						company="Digital Solutions"
						comment="Working with Mateo was a game-changer. He transformed our outdated website into a modern, responsive platform that our customers love."
					/>
					<TestimonialCard
						name="Maria García"
						role="Marketing Director"
						company="Creative Agency"
						comment="Mateo's understanding of both design and development made collaboration seamless. He consistently exceeded expectations on every project."
					/>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Featured In</h2>
					<p>
						I have been fortunate enough to recieve praise for my
						work in several publications.
					</p>
				</header>

				<div class="gallery">
					<div class="marquee-container">
						<div class="marquee-content">
							{
								/* Duplicate items for seamless loop */
								[...Array(10)].map((_, index) => (
									<div class="mention-card">
										<img
											src={`/assets/mentions/${index % 5}.png`}
											alt={`Client ${index % 5}`}
											width="150"
											height="75"
											loading="lazy"
											onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
										/>
										<span style="display:none; font-weight:bold; color:var(--gray-300)">
											CLIENTE {(index % 5) + 1}
										</span>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		position: relative;
		padding: 2rem;
		border-radius: 2rem;
		overflow: hidden;
		overflow: hidden;
		/* Ensure text is above canvas */
		z-index: 1;
	}

	/* 3D Canvas Container override if needed */
	.hero :global(canvas) {
		z-index: -1;
	}

	.web-card {
		border-radius: 1.5rem;
		background: rgba(var(--gray-999-basis), 0.7);
		border: 1px solid var(--gray-800);
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
		position: relative;
	}

	.web-card::after {
		content: '';
		position: absolute;
		top: -2px; left: -2px; right: -2px; bottom: -2px;
		background: linear-gradient(45deg, var(--accent-regular), transparent, var(--accent-dark));
		z-index: -1;
		border-radius: 1.6rem;
		opacity: 0;
		transition: opacity 0.5s ease;
	}

	.web-card:hover {
		transform: translateY(-12px) scale(1.03);
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
		border-color: transparent;
	}

	.web-card:hover::after {
		opacity: 1;
	}

	.web-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.web-image {
		position: relative;
		width: 100%;
		height: 250px;
		background: #000;
		border-bottom: 1px solid var(--gray-800);
		overflow: hidden;
	}

	.web-image::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 50%);
		z-index: 1;
		opacity: 0.6;
		transition: opacity 0.5s ease;
	}

	.web-card:hover .web-image::before {
		opacity: 0;
	}

	.browser-header {
		display: flex;
		gap: 6px;
		padding: 10px 12px;
		background: rgba(20, 20, 20, 0.8);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 2;
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}
	.dot.red { background: #ff5f56; }
	.dot.yellow { background: #ffbd2e; }
	.dot.green { background: #27c93f; }

	.web-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		padding-top: 30px;
		transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.5s ease;
		filter: brightness(0.85);
	}

	.web-card:hover .web-image img {
		transform: scale(1.08);
		filter: brightness(1.1);
	}

	.web-info {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex-grow: 1;
		background: rgba(var(--gray-999-basis), 0.5);
		backdrop-filter: blur(5px);
	}

	.web-info h3 {
		font-size: 1.25rem;
		margin: 0;
		color: var(--gray-100);
	}

	.web-url {
		font-size: 0.875rem;
		color: var(--accent-regular);
		margin: 0;
		opacity: 0.8;
	}

	.visit-btn {
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--gray-300);
		transition: color 0.2s ease;
		padding-top: 1rem;
	}

	.web-card:hover .visit-btn {
		color: var(--accent-text-over);
	}

	.product-card-home {
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		overflow: hidden;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
		height: 100%;
	}

	.product-card-home:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-md);
		border-color: var(--accent-regular);
	}

	.product-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.product-image {
		height: 200px;
		width: 100%;
		position: relative;
		overflow: hidden;
	}

	.product-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.product-card-home:hover .product-image img {
		transform: scale(1.1);
	}

	.price-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: var(--accent-regular);
		color: white;
		padding: 0.25rem 0.75rem;
		border-radius: 99rem;
		font-weight: bold;
		font-size: 0.9rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}

	.product-info {
		padding: 1.5rem;
		background: rgba(var(--gray-999-basis), 0.5);
		backdrop-filter: blur(5px);
	}

	.product-info h3 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.product-info p {
		color: var(--gray-400);
		font-size: 0.9rem;
	}

	.hero::before {
		content: "";
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: linear-gradient(
			45deg,
			var(--accent-dark) 0%,
			var(--accent-regular) 25%,
			var(--accent-light) 50%,
			var(--accent-regular) 75%,
			var(--accent-dark) 100%
		);
		opacity: 0.03;
		animation: rotate-gradient 15s linear infinite;
		z-index: -1;
	}

	@keyframes rotate-gradient {
		0% {
			transform: rotate(0deg);
		}
		100% {
			transform: rotate(360deg);
		}
	}

	.roles {
		display: none;
	}

	.download-cv {
		display: inline-flex;
		padding: 0.5rem 1rem;
		gap: 0.5rem;
		color: var(--accent-text-over);
		border: 1px solid var(--accent-regular);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-md);
		line-height: 1.35;
		white-space: nowrap;
		text-decoration: none;
		align-items: center;
		transition: all 0.3s ease;
		margin-top: 0.5rem;
	}

	.download-cv:hover {
		background-color: var(--accent-dark);
		border-color: var(--accent-dark);
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.hero img {
		aspect-ratio: 3 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-lg);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
		border: 3px solid rgba(255, 255, 255, 0.1);
	}

	.hero img:hover {
		transform: scale(1.02) translateY(-5px);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
			align-items: center;
		}

		.download-cv {
			margin-top: 0;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: "";
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url("/assets/backgrounds/noise.png") top center/220px repeat,
