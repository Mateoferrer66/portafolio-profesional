---
interface Props {
  name: string;
  role: string;
  comment: string;
  image?: string;
  company?: string;
}

const { name, role, comment, image, company } = Astro.props;

// Generate initials from name for avatar fallback
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
---

<div class="testimonial">
  <div class="testimonial-glow"></div>
  
  <!-- Stars -->
  <div class="stars" aria-label="5 stars">
    {'★'.repeat(5)}
  </div>

  <blockquote class="testimonial-quote">
    <span class="quote-mark">"</span>{comment}<span class="quote-mark">"</span>
  </blockquote>

  <div class="testimonial-author">
    {image ? (
      <img src={image} alt={name} class="author-image" width="48" height="48" loading="lazy" />
    ) : (
      <div class="author-avatar">{initials}</div>
    )}
    <div class="author-info">
      <div class="author-name">{name}</div>
      <div class="author-role">
        {role}
        {company && <span class="author-company"> · {company}</span>}
      </div>
    </div>
  </div>
</div>

<style>
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.5rem;
    border-radius: 1.75rem;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(124, 58, 237, 0.07) 50%,
      rgba(6, 182, 212, 0.03) 100%
    );
    border: 1px solid rgba(124, 58, 237, 0.18);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                border-color 0.4s ease;
  }

  .testimonial:hover {
    transform: translateY(-6px);
    border-color: rgba(124, 58, 237, 0.4);
    box-shadow:
      0 24px 60px rgba(124, 58, 237, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .testimonial-glow {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
    pointer-events: none;
    border-radius: 50%;
  }

  .stars {
    color: #fbbf24;
    font-size: 1.1rem;
    letter-spacing: 2px;
  }

  .testimonial-quote {
    font-size: var(--text-md);
    font-style: italic;
    color: var(--gray-100);
    line-height: 1.75;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .quote-mark {
    color: #7c3aed;
    font-size: 1.4em;
    font-style: normal;
    line-height: 0;
    vertical-align: -0.3em;
  }

  .testimonial-author {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(124, 58, 237, 0.15);
    position: relative;
    z-index: 1;
  }

  .author-image {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(124, 58, 237, 0.4);
  }

  /* Avatar fallback with gradient */
  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #06b6d4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: white;
    flex-shrink: 0;
    border: 2px solid rgba(124, 58, 237, 0.4);
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .author-name {
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--gray-0);
  }

  .author-role {
    font-size: var(--text-sm);
    color: var(--gray-400);
  }

  .author-company {
    color: #a78bfa;
  }

  @media (min-width: 50em) {
    .testimonial {
      padding: 2.75rem;
    }

    .testimonial-quote {
      font-size: var(--text-lg);
    }
  }
</style>
