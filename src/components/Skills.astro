---
import Icon from "./Icon.astro";

const skills = [
  {
    icon: "terminal-window" as const,
    title: "Full Stack",
    description:
      "Specialized in Frontend and Backend with React, Angular, Astro, Node.js, Java, Tailwind CSS and TypeScript. Scalable architectures connected to SQL/NoSQL databases and deployed to AWS, Azure & Google Cloud.",
    tags: ["React", "Node.js", "Astro", "TypeScript"],
  },
  {
    icon: "trophy" as const,
    title: "Industry Leader",
    description:
      "200+ certifications from Platzi, Google, Udemy and more. Excellent communication and creative skills, self-driven innovation mindset and the ability to deliver quality results under pressure.",
    tags: ["200+ Certs", "Agile", "DevOps", "AI"],
  },
  {
    icon: "strategy" as const,
    title: "Strategy-Minded",
    description:
      "I combine technical deep-dives with strategic vision. I drive campaigns for software products, design UX-first products and grow digital brands with measurable and data-driven results.",
    tags: ["Marketing", "UX", "SEO", "Analytics"],
  },
];
---

<section class="skills-wrapper">
  {
    skills.map((skill) => (
      <div class="skill-card">
        <div class="skill-glow" />
        <div class="skill-header">
          <div class="skill-icon-wrap">
            <Icon icon={skill.icon} color="var(--accent-regular)" size="2rem" gradient />
          </div>
          <h2 class="skill-title">{skill.title}</h2>
        </div>
        <p class="skill-description">{skill.description}</p>
        <div class="skill-tags">
          {skill.tags.map((tag) => (
            <span class="skill-tag">{tag}</span>
          ))}
        </div>
      </div>
    ))
  }
</section>

<style>
  .skills-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 1.75rem;
    border-radius: 1.75rem;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(124, 58, 237, 0.07) 50%,
      rgba(6, 182, 212, 0.02) 100%
    );
    border: 1px solid rgba(124, 58, 237, 0.16);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                border-color 0.4s ease;
  }

  .skill-card:hover {
    transform: translateY(-6px);
    border-color: rgba(124, 58, 237, 0.4);
    box-shadow:
      0 24px 60px rgba(124, 58, 237, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  /* Animated background glow blob */
  .skill-glow {
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.13) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    transition: transform 0.5s ease, opacity 0.4s ease;
    opacity: 0.7;
  }

  .skill-card:hover .skill-glow {
    transform: scale(1.3);
    opacity: 1;
  }

  .skill-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .skill-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(6, 182, 212, 0.12));
    border: 1px solid rgba(124, 58, 237, 0.25);
    flex-shrink: 0;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .skill-card:hover .skill-icon-wrap {
    transform: rotate(-5deg) scale(1.1);
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.4);
  }

  .skill-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--gray-0);
    letter-spacing: 0.01em;
  }

  .skill-description {
    font-size: var(--text-sm);
    color: var(--gray-300);
    line-height: 1.75;
    position: relative;
    z-index: 1;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
    margin-top: 0.25rem;
  }

  .skill-tag {
    padding: 0.25rem 0.75rem;
    border-radius: 99rem;
    font-size: var(--text-xs, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(6, 182, 212, 0.12));
    border: 1px solid rgba(124, 58, 237, 0.25);
    color: #c4b5fd;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .skill-tag:hover {
    background: rgba(124, 58, 237, 0.35);
    border-color: rgba(124, 58, 237, 0.5);
    color: #ede9fe;
  }

  @media (min-width: 50em) {
    .skills-wrapper {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .skill-card {
      padding: 2.5rem;
    }

    .skill-title {
      font-size: var(--text-2xl);
    }

    .skill-description {
      font-size: var(--text-md);
    }
  }
</style>
